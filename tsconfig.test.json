{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "../../src/*": ["src/*"]
    }
  },
  "include": ["tests/**/*.ts", "src/**/*.ts"]
}

