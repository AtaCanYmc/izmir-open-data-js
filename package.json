{
  "name": "izmir-open-data-js",
  "version": "1.2.5",
  "description": "Izmir Open Data API wrapper - İzmir Büyükşehir Belediyesi Açık Veri API'leri için TypeScript/JavaScript kütüphanesi",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "izmir",
    "api",
    "open-data",
    "turkey",
    "municipality",
    "typescript",
    "eshot",
    "izban",
    "metro",
    "ckan",
    "otopark"
  ],
  "author": "Ata",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/AtaCanYmc/izmir-open-data-js"
  },
  "homepage": "https://github.com/AtaCanYmc/izmir-open-data-js#readme",
  "bugs": {
    "url": "https://github.com/AtaCanYmc/izmir-open-data-js/issues"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/fetch-jsonp": "^1.0.0",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/expect": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint 'src/**/*.{ts,js}' 'tests/**/*.{ts,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,js}' 'tests/**/*.{ts,js}' --fix",
    "format": "prettier --write 'src/**/*.{ts,js}' 'tests/**/*.{ts,js}'",
    "test": "vitest run --exclude tests/integration/**",
    "test:watch": "vitest --exclude tests/integration/**",
    "test:coverage": "vitest run --coverage --exclude tests/integration/**",
    "test:live": "LIVE_API_TESTS=1 vitest run tests/integration/",
    "test:all": "LIVE_API_TESTS=1 vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "fetch-jsonp": "^1.4.0"
  }
}
