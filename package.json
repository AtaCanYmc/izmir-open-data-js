{
  "name": "@ata/izmir-open-data",
  "version": "1.0.0",
  "description": "Izmir Open Data API wrapper",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "izmir",
    "api",
    "open-data"
  ],
  "author": "Ata",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/expect": "^4.0.18",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --exclude tests/integration/**",
    "test:watch": "vitest --exclude tests/integration/**",
    "test:coverage": "vitest run --coverage --exclude tests/integration/**",
    "test:live": "LIVE_API_TESTS=1 vitest run tests/integration/",
    "test:all": "LIVE_API_TESTS=1 vitest run",
    "prepublishOnly": "npm run build"
  }
}
